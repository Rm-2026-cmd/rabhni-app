{
    "version":  2,
    "builds":  [
                   {
                       "src":  "api/**/*.js",
                       "use":  "@vercel/node"
                   },
                   {
                       "src":  "package.json",
                       "use":  "@vercel/static-build",
                       "config":  {
                                      "distDir":  "dist"
                                  }
                   }
               ],
    "routes":  [
                   {
                       "src":  "/api/(.*)",
                       "dest":  "/api/$1"
                   },
                   {
                       "src":  "/(.*)",
                       "dest":  "/index.html"
                   }
               ],
    "crons":  [
                  {
                      "path":  "/api/cron/weekly-reset",
                      "schedule":  "0 21 * * 0"
                  },
                  {
                      "path":  "/api/cron/daily-reset",
                      "schedule":  "0 21 * * *"
                  }
              ]
}
